{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "globals": {
    "URL": "readonly",
    "URLSearchParams": "readonly",
    "Response": "readonly",
    "fetch": "readonly",
    "setTimeout": "readonly"
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn",
    "no-debugger": "error",
    "no-unused-vars": "error",
    "no-undef": "error",
    "typescript/no-explicit-any": "error"
  }
}
